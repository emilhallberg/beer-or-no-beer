# Local development overrides for `npm run dev`
# Copy this file to `.env.development.local` when you want the app to talk to
# your local Supabase stack instead of the hosted project in `.env.local`.

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
ADMIN_USER_IDS=user_123,user_456

# Local Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
